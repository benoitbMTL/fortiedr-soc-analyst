FORTIEDR_HOST=fortiedr.example.com
FORTIEDR_ORG=ExampleOrg
FORTIEDR_USER=api-user
FORTIEDR_PASS=change-me

# Optional compatibility aliases supported by the server:
# FORTIEDR_API_USER=api-user
# FORTIEDR_API_PASSWORD=change-me

# Optional runtime settings:
FORTIEDR_VERIFY_SSL=true
FORTIEDR_TIMEOUT_SECONDS=30
FORTIEDR_ANALYSIS_DB_PATH=./data/analysis_runs.sqlite3
FORTIEDR_BACKEND_HOST=127.0.0.1
FORTIEDR_BACKEND_PORT=8080

# Enable the portal "Clear DB" button and POST /analysis/database/clear endpoint.
FORTIEDR_ENABLE_DB_RESET=true

# Optional OpenAI settings for the structured analysis CLI:
# OPENAI_API_KEY=sk-proj-...
# OPENAI_MODEL=gpt-4.1-mini
# OPENAI_AVAILABLE_MODELS=gpt-4.1-nano,gpt-4.1-mini,gpt-4.1,gpt-4o-mini,gpt-4o
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MAX_TOKENS=4096
# OPENAI_TIMEOUT_SECONDS=120
# OPENAI_TEMPERATURE=0

# Optional Anthropic settings for the structured analysis CLI:
# ANTHROPIC_API_KEY=...
# ANTHROPIC_MODEL=claude-3-5-sonnet-latest
# ANTHROPIC_BASE_URL=https://api.anthropic.com
# ANTHROPIC_MAX_TOKENS=4096
# ANTHROPIC_TIMEOUT_SECONDS=120

# Optional remote Ollama settings for the portal/backend:
# FORTIEDR_LLM_SERVER_PROVIDER=ollama
# FORTIEDR_LLM_SERVER_URL=http://10.163.3.76:11434/
# OLLAMA_BASE_URL=http://10.163.3.76:11434/
# OLLAMA_MODEL=qwen2.5:14b
# OLLAMA_AVAILABLE_MODELS=qwen2.5:14b
# OLLAMA_MAX_TOKENS=4096
# OLLAMA_TIMEOUT_SECONDS=120
# OLLAMA_TEMPERATURE=0
